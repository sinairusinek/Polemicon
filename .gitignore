# Ignore large data and model files
*.csv
*.tsv
*.xlsx
*.xls
*.parquet
*.npy
*.npz
*.faiss
*.pkl
*.pickle
*.h5
*.hdf5
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.index
*.joblib
.DS_Store
# Allow annotation data for Streamlit Cloud
!data/
!data/*.parquet
!data/compact_memory/
!data/compact_memory/*.parquet
!data/compact_memory/*.json
!data/compact_memory/*.md
!data/compact_memory/extracted/
!data/compact_memory/extracted/*.parquet
# Exclude raw PDFs (3.1 GB)
data/compact_memory/raw/
data/compact_memory/sample_*.pdf
# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/
# Ignore Python cache and environment files
__pycache__/
*.pyc
*.pyo
*.pyd
env/
.venv/
venv/
ENV/
.env
.env.*
!.env.template
# Ignore VS Code settings
.vscode/
# Ignore logs
*.log